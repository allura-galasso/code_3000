   "source": [
    "model = RandomForestRegressor(\n",
    "    n_estimators=200,\n",
    "    random_state=seed\n",
    ")\n",
    "model.fit(X_train, y_train)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "acbf0e6b",
   "metadata": {},
   "source": [
    "### Use SHAP to explain the model on test data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "c3eb6137",
   "metadata": {},
   "outputs": [
    {
