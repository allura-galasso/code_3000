   ]
  },
  {
   "cell_type": "markdown",
   "id": "a37c3bc9",
   "metadata": {},
   "source": [
    "### Import the `group` variable, which was **not** used in training this model."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "aaf63702",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_test_with_group = X_test.copy()\n",
    "X_test_with_group[\"group\"] = df.loc[X_test.index, \"group\"]"
   ]
  },
