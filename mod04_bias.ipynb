     "text": [
      " 99%|===================| 1478/1500 [00:44<00:00]        "
     ]
    }
   ],
   "source": [
    "explainer = shap.Explainer(model, X_train)\n",
    "shap_values = explainer(X_test)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ea36e22c",
   "metadata": {},
   "source": [
    "This will allow us to see which variables are most important to predicting the outcome."
